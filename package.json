{
  "name": "my-saas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --stream --filter @my-saas/worker --filter @my-saas/landing --filter @my-saas/admin dev",
    "dev:remote": "pnpm --parallel --stream --filter @my-saas/worker dev:remote --filter @my-saas/landing dev --filter @my-saas/admin dev",
    "dev:apps": "pnpm --parallel --stream --filter @my-saas/landing --filter @my-saas/admin dev",
    "dev:worker": "pnpm --filter @my-saas/worker dev",
    "build": "pnpm build:landing && pnpm build:admin",
    "build:landing": "pnpm --filter @my-saas/landing build:cloudflare",
    "build:admin": "pnpm --filter @my-saas/admin build:cloudflare",
    "check": "pnpm --recursive run check",
    "test": "pnpm --filter @my-saas/worker test",
    "deploy:staging": "pnpm build && pnpm --filter @my-saas/worker db:migrate:remote:staging && pnpm --filter @my-saas/worker deploy:staging",
    "deploy:prod": "pnpm build && pnpm --filter @my-saas/worker db:migrate:remote && pnpm --filter @my-saas/worker deploy"
  }
}
