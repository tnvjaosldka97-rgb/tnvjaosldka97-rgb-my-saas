{
  "name": "@my-saas/worker",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "dev:remote": "wrangler dev --remote --port 8787",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:migrate:remote:staging": "wrangler d1 migrations apply DB --remote --env staging",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@my-saas/com": "workspace:*",
    "agents": "^0.7.9",
    "hono": "^4.12.12",
    "hono-agents": "^3.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vitest": "^4.1.3",
    "wrangler": "^4.80.0"
  }
}
